# настройки Postgres
POSTGRES_DB=taskprocessor_db
POSTGRES_USER=taskprocessor
POSTGRES_PASSWORD=taskprocessor

# порт Postgres внутри контейнера
POSTGRES_PORT=5432

# порт Postgres на хосте (если нужно подключаться с хоста)
POSTGRES_HOST_PORT=5433

# ключ для внешнего AI-сервиса (если используешь RealAiServiceClient)
AI_API_KEY = "sekret"